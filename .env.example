# example environment variables for ai-daily-brief\n\n# gmail oauth client id and secret\nGMAIL_CLIENT_ID=your-client-id\nGMAIL_CLIENT_SECRET=your-client-secret\nGMAIL_REFRESH_TOKEN=your-refresh-token\n\n# comma‑separated list of email recipients for the daily brief\nDAILY_BRIEF_RECIPIENTS=example@example.com,second@example.com\n